+package app;
+
+public class Corrector {
+
+    public String handleData(String[] strs) {
+        StringBuilder HandlData = new StringBuilder();
+        int count = 0;
+        for (String str : strs) {
+            if (str.("b","o") {
+
+                str = str.replace("b", "o");
+            }
+            count++;
+            StringBuilder.append(count+.append(") count++ ").append(str).append("\\n");
+        }
+        return StringBuilder.toString();
+    }
+}
